---
import { siteConfig } from '@/data/site';

const useMailto = siteConfig.contact.formMode === 'mailto' || !siteConfig.contact.formAction;
const formAction = useMailto ? '#' : siteConfig.contact.formAction;
---
<div class="form-shell">
  <div class="form-card">
    <span class="eyebrow">Get a workflow audit</span>
    <h2 style="margin: 0.7rem 0 0.8rem; letter-spacing: -0.04em;">Tell us where the workflow is breaking down.</h2>
    <p class="muted">We focus on practical workflow bottlenecks - lead response, missed-call recovery, booking handoff, admin triage, and team adoption.</p>
    <form id="workflow-audit-form" class="form-grid" action={formAction} method="POST" data-mode={useMailto ? 'mailto' : 'post'} data-email={siteConfig.contact.email}>
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="company">Company</label>
        <input id="company" name="company" autocomplete="organization" required />
      </div>
      <div class="field">
        <label for="email">Work email</label>
        <input id="email" type="email" name="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="industry">Industry</label>
        <select id="industry" name="industry" required>
          <option value="">Select one</option>
          <option>Home services</option>
          <option>Property management</option>
          <option>Independent insurance</option>
          <option>Other small business</option>
        </select>
      </div>
      <div class="field full">
        <label for="tools">Current tools</label>
        <input id="tools" name="tools" placeholder="CRM, phone system, inbox tools, scheduling tools, chat, spreadsheets" />
      </div>
      <div class="field full">
        <label for="problem">What is the main workflow problem right now?</label>
        <textarea id="problem" name="problem" required placeholder="Example: missed calls are not followed up consistently, quote requests sit too long, too much intake work is manual, admin staff rewrite the same messages all day"></textarea>
      </div>
      <div class="field full">
        <button class="button" type="submit">Request the workflow audit</button>
      </div>
      <div class="field full">
        <p class="small muted">{siteConfig.contact.responseTime}</p>
      </div>
    </form>
  </div>
  <aside class="contact-card">
    <h3 style="margin-top: 0;">What happens next</h3>
    <ul class="check-list">
      <li>We review the workflow issue you described.</li>
      <li>We confirm fit and whether the problem is narrow enough for a practical first sprint.</li>
      <li>We recommend the best next step: audit only, sprint, or hold off if the workflow is not ready.</li>
    </ul>
    <div class="divider"></div>
    <h3>Best fit</h3>
    <div class="pill-row">
      <span class="pill">Home services</span>
      <span class="pill">Lead response</span>
      <span class="pill">Missed-call recovery</span>
      <span class="pill">Booking handoff</span>
    </div>
    <div class="divider"></div>
    <p class="small muted">Prefer direct email? Reach us at <a class="highlight" href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>.</p>
    <p class="note small">Static-site note: the current build uses an email-friendly fallback so the form still works on GitHub Pages without a backend. A form endpoint can be added later without redesigning the page.</p>
  </aside>
</div>
<script is:inline>
  const form = document.getElementById('workflow-audit-form');
  if (form?.dataset.mode === 'mailto') {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = form.dataset.email || '';
      const subject = `Workflow audit request - ${data.get('company') || 'New inquiry'}`;
      const lines = [
        `Name: ${data.get('name') || ''}`,
        `Company: ${data.get('company') || ''}`,
        `Email: ${data.get('email') || ''}`,
        `Industry: ${data.get('industry') || ''}`,
        `Tools: ${data.get('tools') || ''}`,
        '',
        'Main workflow problem:',
        `${data.get('problem') || ''}`,
      ];
      const body = encodeURIComponent(lines.join('\n'));
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${body}`;
    });
  }
</script>
